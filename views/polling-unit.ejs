    <!-- 2. LGA Dropdown (Ensure it has an id) -->
    <select id="lgaSelect" disabled>


           <option value="">--Select Local Government--</option>
    </select>

    <!-- 3. Ward Dropdown (Your existing select element) -->
    <select id="wardSelect" disabled>
        <option value="">--Select Ward--</option>
    </select>
    <br>

    <!-- 4. Click Search Button -->
    <button type="submit" id="searchButton">Search</button>
    
    <!-- Below your search form -->
    <div id="resultsContainer" class="results-table-container"></div>
</form>

    <table style="width: 100%; border-collapse: collapse; margin-top: 15px; font-family: Arial, sans-serif;">
        <thead>
            <tr style="background-color: #005f00; color: white; text-align: left;">
                <th style="padding: 10px; border: 1px solid #ddd;">ID</th>
                <th style="padding: 10px; border: 1px solid #ddd;">Unit Name</th>
                <th style="padding: 10px; border: 1px solid #ddd;">Sheet Code</th>
                <th style="padding: 10px; border: 1px solid #ddd;">Counting Status</th>
            </tr>
        </thead>
        <tbody>
            <% if (units.length === 0) { %>
                <tr>
                    <td colspan="4" style="padding: 15px; text-align: center; color: #888; font-style: italic;">
                        No polling units currently found in database. Add records in Studio!
                    </td>
                </tr>
            <% } else { %>
                <% units.forEach(unit => { %>
                    <tr style="border-bottom: 1px solid #ddd; background-color: #fff;">
                        <td style="padding: 10px; border: 1px solid #ddd;"><%= unit.id %></td>
                        <td style="padding: 10px; border: 1px solid #ddd; font-weight: bold;"><%= unit.name %></td>
                        <td style="padding: 10px; border: 1px solid #ddd; color: #444;"><%= unit.sheetCode %></td>
                        <td style="padding: 10px; border: 1px solid #ddd;">
                                                  <td style="padding: 10px; border: 1px solid #ddd;">
                            <% if (unit.isReady) { %>
                                <span style="padding: 3px 6px; border-radius: 4px; font-size: 12px; font-weight: bold; background-color: #e2f0d9; color: #385723;">
                                    Results Transmitted
                                </span>
                            <% } else { %>
                                <span style="padding: 3px 6px; border-radius: 4px; font-size: 12px; font-weight: bold; background-color: #fff2cc; color: #7f6000;">
                                    In Progress...
                                </span>
                            <% } %>
                        </td>

                        </td>
                    </tr>
                <% }) %>
            <% } %>
        </tbody>
    </table>



<ul>
