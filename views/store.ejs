<header>
    <ul>
        <li><a href="/index">Back</a></li>
    </ul>
    <hr>
    <h2>List Of Presidential Candidates</h2>
    <h4>(APC) Bola Tinubu</h4>
    <h4>(PDP) Atiku Abubakar</h4>
    <h4>(ADC) faction Kachikwu Dumebi Kachikwu</h4>
    <h4>(AAC) Omoyele Sowore</h4>
    <h4>(SDP) Adewole Adebayo</h4>
    <h4>(NDC) Peter Obi</h4>
    <h4>(AP) Gbenga Olawepo-Hashim</h4>
    <h4>(APM) Seyi Makinde</h4>
    <h4>(ADP) Aliyu Bin Abbas</h4>
</header>

<footer>
    <h3>Election Parties</h3>
    <ul style="list-style: none; display: flex; gap: 15px; flex-wrap: wrap; padding: 0;">
        <% parties.forEach(party => { %>
            <li style="display: flex; flex-direction: column; align-items: center; width: 100px; text-align: center;">
                <!-- Displays the custom database image path -->
                <img src="<%= party.imagePath %>" height="40" width="40" alt="<%= party.name %> Logo" style="object-fit: contain; border-radius: 4px;">
                
                <!-- Displays the short acronym (e.g., APC, PDP) -->
                <strong style="font-size: 14px; margin-top: 5px;"><%= party.acronym %></strong>
                
                <!-- Displays the full name on a small caption -->
                <span style="font-size: 11px; color: #555;"><%= party.name %></span>
            </li>
        <% }) %>
    </ul>
</footer>
