<!-- views/Home.ejs -->
<div class="inec-page-wrapper">

  <!-- 1. Top Green Address Banner -->
  <div class="inec-top-banner">
    <div class="banner-left-address">
      <span class="location-icon">📍</span> Address: Plot 436 Zambezi Crescent, Maitama District, FCT, Abuja, NIGERIA
    </div>
    <div class="banner-right-socials">
      <!-- Social Media Anchors placed on the right edge -->
      <a href="#" class="social-btn facebook-btn">f</a>
      <a href="#" class="social-btn twitter-btn">𝕏</a>
      <a href="#" class="social-btn instagram-btn">📷</a>
      <a href="#" class="social-btn youtube-btn">▶</a>
    </div>
  </div>

  <!-- 2. Main Logo Header -->
  <header class="inec-main-header">
    <div class="inec-branding-logo">
      <img src="/images/inec-logo.png" alt="INEC Logo" class="brand-img-asset">
      <div class="brand-text-container">
        <h1 class="brand-title-main">INDEPENDENT</h1>
        <p class="brand-subtitle-sub">National Electoral Commission</p>
      </div>
    </div>
  </header>

  <!-- 3. Top Navigation Link Bar -->
  <nav class="inec-navigation-bar">
    <ul class="nav-links-list">
      <li class="nav-item active"><a href="#">Home</a></li>
      <li class="nav-item dropdown"><a href="#">About ▾</a></li>
      <li class="nav-item dropdown"><a href="#">Office of The Chairman ▾</a></li>
      <li class="nav-item dropdown"><a href="#">Voter Education ▾</a></li>
      <li class="nav-item dropdown"><a href="#">Political Parties ▾</a></li>
      <li class="nav-item dropdown emphasis-green-tab"><a href="#">Elections ▾</a></li>
      <li class="nav-item dropdown"><a href="#">Voter Registration ▾</a></li>
      <li class="nav-item dropdown"><a href="#">Resources ▾</a></li>
      <li class="nav-item"><a href="#">Contact Us</a></li>
      <li class="nav-item search-icon-item"><a href="#">🔍</a></li>
    </ul>
  </nav>

  <!-- 4. Grey Section Page Title Banner -->
  <section class="inec-title-hero-banner">
    <h2 class="hero-page-heading">Polling Units</h2>
  </section>

  <!-- 5. Main Content Wrapper (Split-Screen Column Layout) -->
  <main class="inec-content-split-layout">
    
    <!-- Left Column: Tool Description and Dropdowns -->
    <section class="main-left-column-content">
      <p class="inec-descriptive-paragraph">
        At a polling unit, a citizen can either register to vote or vote. It is advisable to select a Polling Unit close to your area of residence due to the restricted movement on election days.
      </p>
      
      <p class="inec-descriptive-paragraph">
        You can locate your polling unit by using the Polling Unit Locator Tool.
      </p>

      <div class="lookup-steps-container">
        <p class="steps-heading-text">To view your polling unit, follow the steps below;</p>
        <ol class="ordered-steps-list">
          <li class="step-list-item">Select State <span class="step-helper-instruction">(This is the state you would be voting in)</span></li>
          <li class="step-list-item">Select LGA <span class="step-helper-instruction">(This is the LGA in which you live)</span></li>
          <li class="step-list-item">Select Ward</li>
          <li class="step-list-item">Click "Search"</li>
        </ol>
      </div>

      <!-- EJS Dropdown Select Form -->
      <form action="/search-polling-units" method="GET" class="inec-lookup-dropdown-form">
        <div class="custom-select-wrapper">
          <select name="state" class="inec-interactive-dropdown-select">
            <option value="">Choose State</option>
            <!-- Add state options dynamically if needed -->
          </select>
        </div>
      </form>
    </section>

    <!-- Right Column: Sidebar Information Green Card Box -->
    <aside class="sidebar-right-column-panel">
      <div class="inec-information-sidebar-card">
        <h3 class="sidebar-card-title-heading">INFORMATION</h3>
        <ul class="sidebar-links-bullet-list">
          <li class="sidebar-bullet-item"><a href="#">INEC Portals</a></li>
          <li class="sidebar-bullet-item"><a href="#">INEC Youth Ambassadors</a></li>
          <li class="sidebar-bullet-item"><a href="#">Election Officials</a></li>
          <li class="sidebar-bullet-item"><a href="#">Election Management Bodies</a></li>
          <li class="sidebar-bullet-item"><a href="#">INEC State and LGA Offices</a></li>
        </ul>
      </div>
    </aside>

  </main>

</div>
