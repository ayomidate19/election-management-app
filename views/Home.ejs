<link rel="stylesheet" href="/stylesheet-home.css">

<header>
    <nav>
        <ul>
            <li><a href="/index">LOG IN</a></li>
            <li><a href="/about">About</a></li>
        </ul>
    </nav>
    <hr>
    <h1>Election Management App</h1>
</header>

<!-- 1. Hero Image Banner Section -->
<div class="hero-banner">
    <div class="hero-overlay">
        <button class="slider-btn prev-btn">&#10094;</button>
        
        <div class="hero-content">
            <h1>LIST OF CANDIDATES FOR 20TH JUNE BYE-ELECTIONS</h1>
            <a href="#" class="read-more-btn">Read More</a>
        </div>

        <button class="slider-btn next-btn">&#10095;</button>
    </div>

    <!-- Slider dots indicators at the bottom -->
    <div class="slider-dots">
        <span class="dot active"></span>
        <span class="dot"></span>
        <span class="dot"></span>
        <span class="dot"></span>
        <span class="dot"></span>
        <span class="dot"></span>
    </div>
</div>

<!-- 2. Statistics Grid Section -->
<div class="stats-section">
    <div class="stats-container">

        <!-- Box 1: Total Voters -->
        <div class="stat-card">
            <div class="card-main">
                <span class="icon">&#128196;</span>
                <span class="number">93,469,008</span>
            </div>
            <div class="card-footer">Total Voters Registered</div>
        </div>

        <!-- Box 2: Polling Units -->
        <div class="stat-card">
            <div class="card-main">
                <span class="icon">&#127988;</span>
                <span class="number">176,846</span>
            </div>
            <div class="card-footer">Polling Units in Nigeria</div>
        </div>

        <!-- Box 3: Parties -->
        <div class="stat-card">
            <div class="card-main">
                <span class="icon">&#10134;</span>
                <span class="number">22</span>
            </div>
            <div class="card-footer">Registered Political Parties</div>
        </div>

        <!-- Box 4: Next Elections Slider -->
        <div class="stat-card unique-card">
            <div class="card-main header-style">
                <h3>Ekiti Governorship Election (June 20, 2026)</h3>
                <div class="mini-dots">
                    <span class="m-dot active"></span>
                    <span class="m-dot"></span>
                    <span class="m-dot"></span>
                </div>
            </div>
            <div class="card-footer font-center">Next Elections</div>
        </div>

    </div>
</div>
    
        <h3>Election Party</h3>
    <ul style="list-style: none; display: flex; gap: 15px; flex-wrap: wrap; padding: 0;">
        <% parties.forEach(party => { %>
            <li style="display: flex; flex-direction: column; align-items: center; width: 120px; text-align: center; border: 1px solid #ddd; padding: 10px; border-radius: 6px; background-color: #fff;">
                <% if (party.imagePath && !party.imagePath.includes('default.png') && !party.imagePath.startsWith('http')) { %>
    <img src="<%= party.imagePath %>" height="40" width="40" alt="<%= party.name %> Logo" style="object-fit: contain; border-radius: 4px;">
<% } else { %>
    <!-- Displays a clean, localized colored text bubble completely offline -->
    <div style="height: 40px; width: 40px; background-color: #005f00; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: bold; border-radius: 4px; font-size: 14px;">
        <%= party.acronym.substring(0, 3) %>
    </div>
<% } %>

                <strong style="font-size: 14px; margin-top: 5px; color: #333;"><%= party.acronym %></strong>
                <span style="font-size: 11px; color: #666; margin-top: 2px;"><%= party.name %></span>
            </li>
        <% }) %>
    </ul>
