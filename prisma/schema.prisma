datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}


model Party {
  id        Int    @id @default(autoincrement())
  name      String
  acronym   String @unique // For example: APC, PDP, LLP
  imagePath String // The link path like "images/APC.jpeg"
}

model PollingUnit {
  id        Int     @id @default(autoincrement())
  name      String  // Name of the polling unit
  sheetCode String  @unique // To map with your sheet views
  isReady   Boolean @default(false) // Whether results are fully counted
}
